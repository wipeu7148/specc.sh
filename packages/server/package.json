{
  "name": "@specc/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "dev": "tsx watch --tsconfig tsconfig.dev.json src/main.ts",
    "prebuild": "pnpm -C ../types build && pnpm -C ../i18n build",
    "build": "rolldown -c",
    "start": "node dist/main.js",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:generate": "prisma generate"
  },
  "dependencies": {
    "@specc/i18n": "workspace:*",
    "@specc/types": "workspace:*",
    "@aws-sdk/client-s3": "^3.1004.0",
    "@hono/node-server": "^1.19.11",
    "@hono/trpc-server": "^0.4.2",
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "@trpc/server": "^11.12.0",
    "consola": "^3.4.2",
    "dotenv": "^17.3.1",
    "hono": "^4.12.5",
    "ioredis": "^5.10.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "prisma": "^7.4.2",
    "rolldown": "^1.0.0-rc.9",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
