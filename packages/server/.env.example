# ======================================
# Server 环境变量 (本地开发)
# ======================================

# 数据库连接 URL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_stack_db

# -----------------------------------------------------------------------
# 对象存储配置
# 目前支持 S3 兼容协议（MinIO / AWS S3 / 阿里云 OSS）
# 切换存储后端只需修改以下环境变量，无需改代码
# -----------------------------------------------------------------------

# 存储后端类型（目前只有 s3，未来可扩展）
STORAGE_PROVIDER=s3

# --- MinIO 本地开发 ---
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_REGION=us-east-1
STORAGE_BUCKET=avatars
STORAGE_ACCESS_KEY_ID=minioadmin
STORAGE_SECRET_ACCESS_KEY=minioadmin
# 浏览器公共访问 URL（路径风格 path-style = true)
STORAGE_PUBLIC_URL=http://localhost:9000
STORAGE_PATH_STYLE=true

# --- AWS S3 ---
# STORAGE_ENDPOINT=                        # 留空使用 AWS 默认 endpoint
# STORAGE_REGION=us-east-1
# STORAGE_BUCKET=my-bucket
# STORAGE_ACCESS_KEY_ID=<key>
# STORAGE_SECRET_ACCESS_KEY=<secret>
# STORAGE_PUBLIC_URL=https://<bucket>.s3.<region>.amazonaws.com
# STORAGE_PATH_STYLE=false

# --- 阿里云 OSS (S3 兼容 API) ---
# STORAGE_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
# STORAGE_REGION=oss-cn-hangzhou
# STORAGE_BUCKET=my-bucket
# STORAGE_ACCESS_KEY_ID=<AccessKeyId>
# STORAGE_SECRET_ACCESS_KEY=<AccessKeySecret>
# STORAGE_PUBLIC_URL=https://<bucket>.oss-cn-hangzhou.aliyuncs.com
# STORAGE_PATH_STYLE=false

# -----------------------------------------------------------------------
# 速率限制（Rate Limiting）
# -----------------------------------------------------------------------
# 登录接口：15 分钟内同一 IP 最多请求次数
AUTH_LOGIN_MAX_REQUESTS=10
# 登录窗口时长（毫秒），默认 15 分钟
AUTH_LOGIN_WINDOW_MS=900000
# 注册接口：1 小时内同一 IP 最多请求次数
AUTH_REGISTER_MAX_REQUESTS=5
# 注册窗口时长（毫秒），默认 1 小时
AUTH_REGISTER_WINDOW_MS=3600000
