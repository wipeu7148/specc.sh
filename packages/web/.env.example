# ======================================
# Web 环境变量 (本地开发)
# ======================================

# tRPC API 端点
VITE_TRPC_URL=/trpc

# 存储文件公开访问域名前缀（由前端拼接完整 URL，后端只存文件 key）
# MinIO 本地开发示例: http://localhost:9000/avatars
# AWS S3 示例: https://<bucket>.s3.<region>.amazonaws.com
# 阿里云 OSS 示例: https://<bucket>.oss-cn-hangzhou.aliyuncs.com
VITE_STORAGE_PUBLIC_URL=http://localhost:9000/avatars

# 站点公开访问域名（用于 SEO canonical URL / OG 标签）
VITE_SITE_URL=https://specc.sh
